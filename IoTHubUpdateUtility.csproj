<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>IoTHubUpdateUtility</AssemblyName>
    <RootNamespace>IoTHubUpdateUtility</RootNamespace>
    <Version>1.0.0</Version>
    <InformationalVersion>1.0.0</InformationalVersion>
    <Description>Desktop utility for validating and applying IoT Hub update packages on Linux devices.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.3.0" />
    <PackageReference Include="Avalonia.Desktop" Version="11.3.0" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.0" />
    <PackageReference Include="Avalonia.ReactiveUI" Version="11.3.0" />
    <PackageReference Include="SharpCompress" Version="0.38.0" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Reflection.AssemblyMetadataAttribute">
      <_Parameter1>ReleaseDate</_Parameter1>
      <_Parameter2>2026-04-05</_Parameter2>
    </AssemblyAttribute>
  </ItemGroup>

</Project>
