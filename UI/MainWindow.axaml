<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:IoTHubUpdateUtility.UI"
        x:Class="IoTHubUpdateUtility.UI.MainWindow"
        Title="IoT Hub Update Utility"
        Width="1400" Height="860"
        MinWidth="1100" MinHeight="700"
        Background="#1e1e1e">

  <Window.Styles>
    <Style Selector="Button">
      <Setter Property="Background" Value="#0e639c"/>
      <Setter Property="Foreground" Value="#ffffff"/>
      <Setter Property="BorderBrush" Value="#0e639c"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#f44747"/>
      <Setter Property="BorderBrush" Value="#f44747"/>
    </Style>
    <Style Selector="Button:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1177bb"/>
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#f44747"/>
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#3c3c3c"/>
      <Setter Property="Foreground" Value="#cccccc"/>
      <Setter Property="BorderBrush" Value="#3c3c3c"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Padding" Value="8,6"/>
    </Style>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#cccccc"/>
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="ListBox">
      <Setter Property="Background" Value="#1e1e1e"/>
      <Setter Property="BorderBrush" Value="#3c3c3c"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="2,1"/>
      <Setter Property="Margin" Value="0"/>
    </Style>
    <Style Selector="TreeView">
      <Setter Property="Background" Value="#1e1e1e"/>
      <Setter Property="BorderBrush" Value="#3c3c3c"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
    <Style Selector="TreeView ToggleButton">
      <Setter Property="Foreground" Value="#cccccc"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="TreeViewItem">
      <Setter Property="Foreground" Value="#cccccc"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="TreeViewItem ToggleButton">
      <Setter Property="Foreground" Value="#cccccc"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="#cccccc"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="#cccccc"/>
    </Style>
    <Style Selector="RadioButton">
      <Setter Property="Foreground" Value="#cccccc"/>
    </Style>
    <Style Selector="TabItem">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#cccccc"/>
      <Setter Property="Background" Value="#1e1e1e"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="CornerRadius" Value="4"/>
    </Style>
    <Style Selector="TabItem:selected">
      <Setter Property="Foreground" Value="#0e639c"/>
      <Setter Property="Background" Value="#252526"/>
    </Style>
  </Window.Styles>

  <TabControl Background="#1e1e1e">

    <!-- HOME TAB -->
    <TabItem Header="Home" Background="#1e1e1e">
      <!-- Outer grid: Sidebar | Splitter | Main Container -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="300" MinWidth="180"/>
          <ColumnDefinition Width="3"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Explorer Sidebar (full height) -->
        <Border Grid.Column="0" Background="#1e1e1e" Padding="8" Margin="8" BorderThickness="0" VerticalAlignment="Stretch">
          <Border BorderThickness="0" CornerRadius="4" VerticalAlignment="Stretch">
            <TreeView ItemsSource="{Binding SourceTree}" Background="#252526" VerticalAlignment="Stretch">
              <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                  <StackPanel Orientation="Horizontal"
                              Spacing="4"
                              PointerPressed="OnSourceTreeNodePointerPressed">
                    <TextBlock Text="{Binding Icon}" FontSize="12"/>
                    <TextBlock Text="{Binding Name}" Foreground="#cccccc" FontSize="12"/>
                  </StackPanel>
                </TreeDataTemplate>
              </TreeView.ItemTemplate>
            </TreeView>
          </Border>
        </Border>

        <!-- Vertical splitter between Sidebar and Main -->
        <GridSplitter Grid.Column="1" Width="2" Background="#333333" HorizontalAlignment="Center" VerticalAlignment="Stretch" ShowsPreview="True" ResizeDirection="Columns"/>

        <!-- RIGHT: Main Container (contains header, editor zone, horizontal splitter, panel zone) -->
        <Grid Grid.Column="2" Margin="8" VerticalAlignment="Stretch">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="3"/>
              <RowDefinition Height="250"/>
          </Grid.RowDefinitions>

          <!-- Source Path bar at very top of Main Container -->
          <Grid Grid.Row="0" ColumnDefinitions="*,150" ColumnSpacing="10" Margin="0,0,0,8">
            <TextBox Grid.Column="0"
                     Text="{Binding SourcePath}"
                     Watermark="Compressed file or folder path…"
                     HorizontalAlignment="Stretch"/>
            <Button Grid.Column="1"
                    Content="Select source"
                    Click="OnSelectSource"
                    Width="150"
                    HorizontalAlignment="Stretch"/>
          </Grid>

          <!-- Editor Zone (Top): Rules List (left) and Script (right) with vertical splitter -->
          <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="3"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Rules column -->
            <DockPanel Grid.Column="0" Margin="0,0,8,0">
              <Grid DockPanel.Dock="Top" Margin="0,0,0,8" VerticalAlignment="Top">
                <TextBlock Text="Rules List:"
                           FontWeight="SemiBold"
                           Foreground="#006BB8"
                           FontSize="13"
                           VerticalAlignment="Top"/>
              </Grid>

              <Border DockPanel.Dock="Top" BorderThickness="0" CornerRadius="4" Height="250" VerticalAlignment="Top">
                <ListBox ItemsSource="{Binding Rules}"
                         x:Name="RulesListBox"
                         Background="#252526"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Spacing="3" Margin="4">
                        <TextBlock Text="{Binding Name}"      FontWeight="SemiBold" Foreground="#cccccc" FontSize="12"/>
                        <TextBlock Text="{Binding Operation}" Foreground="#999"     FontSize="11"/>
                        <TextBlock Text="{Binding SourceRelativePath, StringFormat='src: {0}'}"
                                   Foreground="#777" FontSize="10"/>
                        <TextBlock Text="{Binding DestinationRelativePath, StringFormat='dst: {0}'}"
                                   Foreground="#777" FontSize="10"/>
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Border>

              <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,8,0,8">
                <Button Content="New"    Click="OnNewRule"    Width="90" MinWidth="90"/>
                <Button Content="Edit"   Click="OnEditRule"   Width="90" MinWidth="90"/>
                <Button Content="Save"   Click="OnSaveRule"   Width="90" MinWidth="90"/>
                <Button Content="Delete" Click="OnDeleteRule" Width="90" MinWidth="90"/>
              </StackPanel>

              <ScrollViewer>
                <StackPanel Spacing="6" x:Name="RuleEditor" IsVisible="True" IsEnabled="False">
                  <TextBlock x:Name="RuleEditorHint" Text="Select a rule and click Edit, or click New." Foreground="#666" FontSize="11"/>
                  <TextBox x:Name="RuleNameBox"    Watermark="Name"                 LostFocus="OnRuleFieldChanged"/>
                  <TextBox x:Name="RuleSrcBox"
                           Watermark="Source relative path"
                           LostFocus="OnRuleFieldChanged"
                           DragDrop.AllowDrop="True"
                           DragDrop.DragOver="OnRuleSourcePathDragOver"
                           DragDrop.Drop="OnRuleSourcePathDrop"/>
                  <TextBox x:Name="RuleDstBox"
                           Watermark="Dest relative path"
                           LostFocus="OnRuleFieldChanged"
                           DragDrop.AllowDrop="True"
                           DragDrop.DragOver="OnRuleDestinationPathDragOver"
                           DragDrop.Drop="OnRuleDestinationPathDrop"/>
                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <CheckBox x:Name="RulePermsCheckBox"
                              Content="Apply"
                              Checked="OnRulePermissionsChanged"
                              Unchecked="OnRulePermissionsChanged"/>
                    <TextBlock x:Name="RulePermsLabel"
                               Text="{Binding Permissions}"
                               VerticalAlignment="Center"
                               Foreground="#999"/>
                  </StackPanel>
                  <ComboBox x:Name="RuleOpBox" Width="180" SelectionChanged="OnRuleOpChanged">
                    <ComboBoxItem Content="RecursiveCopy"/>
                    <ComboBoxItem Content="FilesOnly"/>
                    <ComboBoxItem Content="ReplaceFile"/>
                  </ComboBox>
                </StackPanel>
              </ScrollViewer>
            </DockPanel>

            <!-- Vertical splitter between Rules and Script -->
            <GridSplitter Grid.Column="1" Width="2" Background="#333333" HorizontalAlignment="Center" VerticalAlignment="Stretch" ShowsPreview="True" ResizeDirection="Columns"/>

            <!-- Script column -->
            <DockPanel Grid.Column="2" Margin="8,0,0,0">
              <Grid DockPanel.Dock="Top" ColumnDefinitions="*" Margin="0,0,0,8" VerticalAlignment="Top">
                <TextBlock Text="Script"
                           FontWeight="SemiBold"
                           Foreground="#006BB8"
                           FontSize="13"
                           VerticalAlignment="Top"/>
              </Grid>

                    <Border BorderThickness="0"
                      CornerRadius="4"
                      MinHeight="420"
                      VerticalAlignment="Top">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <TextBox Text="{Binding ScriptText, Mode=TwoWay}"
                           AcceptsReturn="True"
                           TextWrapping="Wrap"
                           FontFamily="Monospace"
                           Background="#252526"
                           Foreground="#e6e6e6"
                           Padding="8"
                           />
                </ScrollViewer>
              </Border>
            </DockPanel>
          </Grid>

          <!-- Horizontal splitter between Editor Zone and Panel Zone -->
          <GridSplitter Grid.Row="2" Height="2" Background="#333333" HorizontalAlignment="Stretch" VerticalAlignment="Center" ShowsPreview="True" ResizeDirection="Rows"/>

          <!-- Panel Zone (Bottom): Buttons row pinned at top, Log Console below -->
          <Border Grid.Row="3" Background="#1e1e1e" Padding="10,8" BorderThickness="0" Margin="0,8,0,0">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>

              <Grid Grid.Row="0" ColumnDefinitions="*,*,*,*,*" ColumnSpacing="10" HorizontalAlignment="Left">
                <Button Grid.Column="0" Content="Check upgrade criteria"      Click="OnCheckCriteria" HorizontalAlignment="Stretch"/>
                <Button Grid.Column="1" Content="Stop services &amp; execute rules" Click="OnStopAndExecute" HorizontalAlignment="Stretch"/>
                <Button Grid.Column="2" Content="Start system services"       Click="OnStartServices" HorizontalAlignment="Stretch"/>
                <Button Grid.Column="3" Content="Refresh Folder Tree" Click="OnRefreshFolderTree" HorizontalAlignment="Stretch"/>
                <Button Grid.Column="4" Content="Clear logs" Click="OnClearLogs" HorizontalAlignment="Stretch"/>
              </Grid>

              <Border Grid.Row="1" BorderThickness="0" CornerRadius="4" Margin="0,8,0,0">
                <ListBox ItemsSource="{Binding LogLines}"
                         Background="#1e1e1e"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         x:Name="LogListBox">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Message}"
                                 FontFamily="Monospace"
                                 FontSize="12"
                                 Foreground="{Binding Foreground}"/>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Border>
            </Grid>
          </Border>

        </Grid>
      </Grid>
    </TabItem>

    <!-- SETTINGS TAB -->
    <TabItem Header="Settings" Background="#1e1e1e">
      <ScrollViewer>
        <StackPanel Spacing="20" Margin="20">

          <!-- Upgrade Source Type -->
          <Border BorderBrush="#3c3c3c" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10" Background="#252526">
            <StackPanel Spacing="8">
              <TextBlock Text="Upgrade Source Type" FontWeight="SemiBold" FontSize="12"/>
              <RadioButton Content="compressed file" IsChecked="{Binding SourceType, Converter={x:Static local:SourceTypeToBoolConverter.CompressedFile}}"/>
              <RadioButton Content="folder" IsChecked="{Binding SourceType, Converter={x:Static local:SourceTypeToBoolConverter.Folder}}"/>
            </StackPanel>
          </Border>

          <!-- Backup Configuration -->
          <Border BorderBrush="#3c3c3c" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10" Background="#252526">
            <StackPanel Spacing="8">
              <TextBlock Text="Backup Configuration" FontWeight="SemiBold" FontSize="12"/>
              <CheckBox Content="Backup old files" IsChecked="{Binding BackupEnabled}"/>
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox Text="{Binding BackupPath}" Watermark="Backup directory path" Width="300"/>
                <Button Content="Select folder" Click="OnSelectBackupPath"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Extract Path Configuration -->
          <Border BorderBrush="#3c3c3c" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10" Background="#252526">
            <StackPanel Spacing="8">
              <TextBlock Text="Extract Path Configuration" FontWeight="SemiBold" FontSize="12"/>
              <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Extract selected file" VerticalAlignment="Center"/>
                <TextBox Text="{Binding ExtractionPath}" Watermark="Extraction directory path" Width="300"/>
                <Button Content="Select folder" Click="OnSelectExtractionPath"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Stop Services -->
          <Border BorderBrush="#3c3c3c" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10" Background="#252526">
            <StackPanel Spacing="8">
              <TextBlock Text="Stop Services" FontWeight="SemiBold" FontSize="12"/>
              <TextBlock Text="Commands to stop services before update:" FontSize="12"/>
              <ListBox ItemsSource="{Binding StopServices}" x:Name="StopServicesListBox" Height="100"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="NewStopServiceBox" Watermark="New stop command" Width="300"/>
                <Button Content="+ Add" Click="OnAddStopService"/>
                <Button Content="− Remove Selected" Click="OnRemoveStopService"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Start Services -->
          <Border BorderBrush="#3c3c3c" BorderThickness="1" CornerRadius="6" Padding="10" Background="#252526">
            <StackPanel Spacing="8">
              <TextBlock Text="Start Services" FontWeight="SemiBold" FontSize="12"/>
              <TextBlock Text="Commands to start services after update:" FontSize="12"/>
              <ListBox ItemsSource="{Binding StartServices}" x:Name="StartServicesListBox" Height="100"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox x:Name="NewStartServiceBox" Watermark="New start command" Width="300"/>
                <Button Content="+ Add" Click="OnAddStartService"/>
                <Button Content="− Remove Selected" Click="OnRemoveStartService"/>
              </StackPanel>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </TabItem>

    <!-- ABOUT TAB -->
    <TabItem Header="About" Background="#1e1e1e">
      <ScrollViewer>
        <Border Background="#252526"
                BorderBrush="#3c3c3c"
                BorderThickness="1"
                CornerRadius="10"
                Padding="24"
                Margin="24">
          <StackPanel Spacing="12">
            <TextBlock Text="{Binding AppTitle}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#ffffff"/>
            <TextBlock Text="{Binding AppDescription}"
                       TextWrapping="Wrap"
                       FontSize="13"
                       Foreground="#d6d6d6"/>
            <TextBlock Text="{Binding AppVersion, StringFormat='Version: {0}'}"
                       FontSize="14"
                       Foreground="#0e639c"/>
            <TextBlock Text="{Binding AppReleaseDate, StringFormat='Release date: {0}'}"
                       FontSize="14"
                       Foreground="#0e639c"/>
          </StackPanel>
        </Border>
      </ScrollViewer>
    </TabItem>

  </TabControl>
</Window>
